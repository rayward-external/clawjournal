__pycache__/
*.pyc
*.egg-info/
/dist/
build/
.DS_Store
*.jsonl

# Frontend build output — built locally via `npm run build`, never committed
clawjournal/web/frontend/dist/

# ClawJournal local export/review artifacts
clawjournal_conversations.jsonl
clawjournal_export.jsonl
findings.json

# Node modules
node_modules/

# Local tooling state
.desloppify/
.worktrees/
.claude/

# docs/ is local-only planning material by default. `/docs/*` (not `/docs/`) so git
# still descends into it — a blanket directory exclude cannot be re-included below.
# The self-improving-skills design set is versioned explicitly, file by file.
/docs/*
!/docs/self-improving-skills/
/docs/self-improving-skills/*
!/docs/self-improving-skills/plan.md
!/docs/self-improving-skills/competitor-comparison.md
!/docs/self-improving-skills/validation-design.md
!/docs/self-improving-skills/validation-design-critique.md

# PII review artifacts
*.pii_findings.json

# Generated dashboards/screenshots — contain real session data, never commit
*_dashboard.html
/search-page*.png
/share-page*.png

# Local-only personalized-benchmark scratch files — contain real PII, never commit
/benchmark-cc.md
/benchmark-codex.md
